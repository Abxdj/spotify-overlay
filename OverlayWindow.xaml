<Window x:Class="SpotifyOverlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SpotifyOverlay"
        Width="260"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- transparent circular hit-area button used on the wheel -->
        <Style x:Key="WheelBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- iPod body -->
    <Border CornerRadius="22" Background="#EE0E0E0E" Padding="16" BorderBrush="#22FFFFFF" BorderThickness="1">
        <StackPanel>

            <!-- close button, top-right -->
            <Button x:Name="CloseBtn" Content="✕" Click="Close_Click"
                    HorizontalAlignment="Right" Foreground="#666" Background="Transparent"
                    BorderThickness="0" FontSize="12" Cursor="Hand" Margin="0,-4,-4,4"/>

            <!-- SCREEN -->
            <Border CornerRadius="6" Background="#000000" Padding="10" BorderBrush="#22FFFFFF" BorderThickness="1">
                <StackPanel>
                    <!-- album art -->
                    <Border Width="150" Height="150" CornerRadius="4"
                            ClipToBounds="True" Background="#222" HorizontalAlignment="Center">
                        <Image x:Name="AlbumArt" Stretch="UniformToFill"/>
                    </Border>

                    <!-- track / artist -->
                    <TextBlock x:Name="TrackName" Text="—"
                               Foreground="White" FontSize="13" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" TextAlignment="Center"
                               Margin="0,8,0,0"/>
                    <TextBlock x:Name="ArtistName" Text=""
                               Foreground="#9A9A9A" FontSize="11"
                               TextTrimming="CharacterEllipsis" TextAlignment="Center"
                               Margin="0,1,0,0"/>

                    <!-- visualizer inside the screen -->
                    <Canvas x:Name="VizCanvas" Height="30" Margin="0,8,0,0" ClipToBounds="True"/>
                </StackPanel>
            </Border>

            <!-- CLICK WHEEL -->
            <Grid Width="170" Height="170" Margin="0,18,0,2" HorizontalAlignment="Center">
                <!-- outer ring -->
                <Ellipse Fill="#1C1C1C" Stroke="#2E2E2E" StrokeThickness="1"/>
                <!-- center button -->
                <Ellipse Width="58" Height="58" Fill="#141414" Stroke="#2E2E2E" StrokeThickness="1"/>

                <!-- center play/pause (hit area over the inner circle) -->
                <Button x:Name="PlayBtn" Content="⏯" Click="Play_Click"
                        Width="58" Height="58" Style="{StaticResource WheelBtn}"
                        FontSize="18"/>

                <!-- prev (left) -->
                <Button x:Name="PrevBtn" Content="⏮" Click="Prev_Click"
                        Width="40" Height="40" Style="{StaticResource WheelBtn}"
                        HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0"/>

                <!-- next (right) -->
                <Button x:Name="NextBtn" Content="⏭" Click="Next_Click"
                        Width="40" Height="40" Style="{StaticResource WheelBtn}"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"/>

                <!-- MENU label (top, decorative) -->
                <TextBlock Text="MENU" Foreground="#555" FontSize="10" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>